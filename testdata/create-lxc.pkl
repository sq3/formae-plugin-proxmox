amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@proxmox/proxmox.pkl"
import "@proxmox/compute/lxc.pkl" as lxc

forma {
  new formae.Stack {
    label = "test-stack"
    description = "Formae test stack"
  }

  new formae.Target {
    label = "proxmox-target2"
    config = new proxmox.Config {
      apiUrl = read?("env:PROXMOX_API_URL")
      node = read?("env:PROXMOX_NODE")
    }
  }

  new lxc.LXC {
    label = "formae-test-container"
    vmid = 400
    ostemplate = "local:vztmpl/debian-12-standard_12.2-1_amd64.tar.zst"
    hostname = "formae-test-container"
    rootfs = "local-lvm:8"
    cores = 1
    memory = 512
    net0 = "name=eth0,bridge=vmbr0,ip=dhcp"
    unprivileged = true
    start = true
    description = "Test container created by formae"
  }
}
