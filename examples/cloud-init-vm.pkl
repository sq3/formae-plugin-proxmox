// SPDX-License-Identifier: Apache-2.0
//
// Example: Create a VM with cloud-init configuration
//
// This example shows how to create a VM that uses cloud-init for
// automated provisioning. Useful for deploying cloud images like
// Ubuntu Cloud, Debian Cloud, or other cloud-init enabled images.
//
// Prerequisites:
//   export PROXMOX_API_URL="https://pve.example.com:8006"
//   export PROXMOX_TOKEN_ID="user@realm!tokenname"
//   export PROXMOX_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
//   export PROXMOX_NODE="pve"
//
// Note: You need a cloud image template. Create one with:
//   wget https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img
//   qm create 9000 --name ubuntu-cloud-template --memory 2048 --cores 2 --net0 virtio,bridge=vmbr0
//   qm importdisk 9000 jammy-server-cloudimg-amd64.img local-lvm
//   qm set 9000 --scsihw virtio-scsi-pci --scsi0 local-lvm:vm-9000-disk-0
//   qm set 9000 --ide2 local-lvm:cloudinit
//   qm set 9000 --boot order=scsi0
//   qm template 9000
//
// Then clone from template: qm clone 9000 100 --name my-vm
//
// Usage:
//   formae eval examples/cloud-init-vm.pkl
//   formae apply --mode reconcile --simulate examples/cloud-init-vm.pkl
//   formae apply --mode reconcile --watch examples/cloud-init-vm.pkl

amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@proxmox/proxmox.pkl"
import "@proxmox/compute/vm.pkl" as vm

local sshKey = read?("env:SSH_PUBLIC_KEY") ?? "ssh-ed25519 AAAA... user@example.com"

forma {
  new formae.Stack {
    label = "cloud-init-stack"
    description = "Cloud-init enabled VM stack"
  }

  new formae.Target {
    label = "proxmox-target"
    config = new proxmox.Config {
      apiUrl = read?("env:PROXMOX_API_URL")
      node = read?("env:PROXMOX_NODE")
    }
  }

  // Cloud-init enabled VM
  new vm.VM {
    label = "cloud-vm"
    vmid = 101
    name = "cloud-vm"
    cores = 2
    sockets = 1
    memory = 4096
    ostype = "l26"
    scsihw = "virtio-scsi-pci"
    bios = "ovmf"  // UEFI for modern cloud images
    machine = "q35"
    cpu = "host"

    // Storage
    scsi0 = "local-lvm:32"  // Main disk
    ide0 = "local-lvm:cloudinit"  // Cloud-init drive

    // Network
    net0 = "virtio,bridge=vmbr0"

    // Boot order
    boot = "order=scsi0"

    // Cloud-init configuration
    ipconfig0 = "ip=dhcp"  // Or use static: "ip=10.0.0.100/24,gw=10.0.0.1"
    nameserver = "8.8.8.8 8.8.4.4"
    searchdomain = "example.com"
    ciuser = "ubuntu"
    sshkeys = sshKey

    // QEMU Guest Agent for better VM management
    agent = "enabled=1"

    // Startup behavior
    onboot = true

    description = "Cloud-init VM created by Formae"
    tags = "formae;cloud-init;ubuntu"
  }
}
