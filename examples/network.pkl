// SPDX-License-Identifier: Apache-2.0
// Example: Proxmox Network Interface Configurations

amends "@formae/formae.pkl"

import "@proxmox/network/network.pkl"

// Main Linux bridge with VLAN awareness for VM networking
main_bridge = new network.Interface {
  label = "vmbr0"
  iface = "vmbr0"
  `type` = "bridge"
  bridge_ports = "enp1s0"
  bridge_vlan_aware = true
  bridge_vids = "2-4094"
  autostart = true
  cidr = "192.168.1.10/24"
  gateway = "192.168.1.1"
  comments = "Main VM bridge with VLAN support"
}

// Secondary bridge for internal VM network (no physical ports)
internal_bridge = new network.Interface {
  label = "vmbr1"
  iface = "vmbr1"
  `type` = "bridge"
  bridge_ports = ""  // Internal only, no physical connection
  autostart = true
  cidr = "10.0.0.1/24"
  comments = "Internal VM network"
}

// Bond interface for high availability
ha_bond = new network.Interface {
  label = "bond0"
  iface = "bond0"
  `type` = "bond"
  slaves = "enp2s0 enp3s0"
  bond_mode = "802.3ad"  // LACP
  bond_xmit_hash_policy = "layer3+4"
  bond_miimon = 100
  autostart = true
  comments = "LACP bond for high availability"
}

// Bridge using the bond interface
bonded_bridge = new network.Interface {
  label = "vmbr-ha"
  iface = "vmbr2"
  `type` = "bridge"
  bridge_ports = "bond0"
  bridge_vlan_aware = true
  autostart = true
  cidr = "10.10.0.1/24"
  comments = "HA bridge on bonded interfaces"
}

// VLAN interface for management network
mgmt_vlan = new network.Interface {
  label = "vlan100"
  iface = "enp1s0.100"
  `type` = "vlan"
  `vlan-id` = 100
  `vlan-raw-device` = "enp1s0"
  autostart = true
  cidr = "172.16.100.10/24"
  comments = "Management VLAN"
}

// Active-backup bond for failover
failover_bond = new network.Interface {
  label = "bond-backup"
  iface = "bond1"
  `type` = "bond"
  slaves = "enp4s0 enp5s0"
  bond_mode = "active-backup"
  bond_primary = "enp4s0"
  bond_miimon = 100
  autostart = true
  comments = "Active-backup bond for failover"
}
