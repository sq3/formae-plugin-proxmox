module proxmox

import "@formae/formae.pkl"

/// Proxmox VE OS types
typealias OsType = "l26" |       // Linux 2.6 - 6.x Kernel
  "l24" |                         // Linux 2.4 Kernel
  "win11" |                       // Microsoft Windows 11/2025
  "win10" |                       // Microsoft Windows 10/2016/2019
  "win8" |                        // Microsoft Windows 8.x/2012
  "win7" |                        // Microsoft Windows 7/2008r2
  "wxp" |                         // Microsoft Windows XP/2003
  "w2k" |                         // Microsoft Windows 2000
  "solaris" |                     // Solaris/OpenSolaris
  "other"                         // Other OS

/// SCSI controller types
typealias ScsiHw = "virtio-scsi-pci" |
  "virtio-scsi-single" |
  "lsi" |
  "lsi53c810" |
  "megasas" |
  "pvscsi"

/// BIOS types
typealias BiosType = "seabios" |
  "ovmf"

/// Proxmox VE target configuration
/// Connection details for a Proxmox VE cluster or node.
open class Config {
  hidden fixed type: String = "Proxmox"

  /// Proxmox API URL (e.g., https://pve.example.com:8006)
  hidden apiUrl: String?

  /// Default node name for resource operations
  hidden node: String?

  /// API token ID (format: user@realm!tokenname)
  hidden tokenId: String?

  /// API token secret (UUID)
  hidden secret: String?

  // Exported fields to target config
  fixed Type: String = type
  fixed ApiUrl: String? = apiUrl
  fixed Node: String? = node
  fixed TokenId: String? = tokenId
  fixed Secret: String? = secret
}

class FieldHint extends formae.FieldHint {}

class ResourceHint extends formae.ResourceHint {
  hidden outputKeyTransformation: (String) -> String = (it) -> it
}

class SubResourceHint extends formae.SubResourceHint {
  hidden outputKeyTransformation: (String) -> String = (it) -> it
}
